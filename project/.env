# ──────────────────────────────────────────────
# AFAB Backend — Environment Variables (EXAMPLE)
# Copy this file as .env and fill in your values
# ──────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=afab
POSTGRES_USER=afab_user
POSTGRES_PASSWORD=afab_secret_2026

# ── Spring Boot App ──────────────────────────
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# ── JWT ──────────────────────────────────────
JWT_SECRET=b3BlbnNlc2FtZS1hZmFiLXN1cGVyLXNlY3JldC1rZXktMjAyNi1qd3QtdG9rZW4tc2lnbmluZy1rZXk=
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── MinIO (S3-Compatible Storage) ────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=afab_minio_access
MINIO_SECRET_KEY=afab_minio_secret_2026
MINIO_BUCKET=afab-receipts

# ── Mail (Mailpit for local dev) ─────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@afab.local

# ── Redis (Optional Cache) ───────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
